datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  password     String
  name         String?
  role         Role        @relation(fields: [roleId], references: [id])
  roleId       Int
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?
  college      College?    @relation(fields: [collegeId], references: [id])
  collegeId    Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  templates      Template[]      @relation("UserTemplates")
  draftTemplates DraftTemplate[] @relation("UserDraftTemplates")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g., 'PRESIDENT', 'COLLEGE_ADMIN', 'DEPARTMENT_ADMIN', etc.
  users User[]
}

model Department {
  id           Int       @id @default(autoincrement())
  name         String    @unique // e.g., 'Computer Science', 'IT', etc.
  code         String?   @unique // Department code (optional for existing records)
  email        String? // Contact email
  phone        String? // Contact phone
  academicYear String? // Academic year
  college      College   @relation(fields: [collegeId], references: [id])
  collegeId    Int
  users        User[]
  students     Student[]
  teachers     Teacher[]
  courses      Course[]
}

model Student {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  phone        String?
  password     String?
  role         String     @default("STUDENT")
  year         String // e.g., "1st Year", "2nd Year", etc.
  sections     String[] // Array of sections
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Teacher {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  phone        String?
  password     String?
  role         String       @default("TEACHER")
  title        String? // e.g., "Professor", "Lecturer", etc.
  department   Department   @relation(fields: [departmentId], references: [id])
  departmentId Int
  enrollments  Enrollment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Course {
  id           Int          @id @default(autoincrement())
  code         String       @unique
  name         String
  credits      Int
  hours        Int?
  instructor   String?
  students     Int          @default(0)
  status       String       @default("active") // "active" | "pending" | "inactive"
  department   Department   @relation(fields: [departmentId], references: [id])
  departmentId Int
  enrollments  Enrollment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  year      String // e.g., "1st Year", "2nd Year"
  section   String // e.g., "Section A", "Section B"
  status    String   @default("active") // "active" | "pending" | "dropped"
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  teacherId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model College {
  id           Int          @id @default(autoincrement())
  name         Json // { en: string, am: string }
  code         String       @unique
  description  Json // { en: string, am: string }
  email        String
  phone        String
  address      Json // { en: string, am: string }
  academicYear String
  status       String // "active" | "inactive"
  users        User[]
  departments  Department[]
}

model Template {
  id             Int      @id @default(autoincrement())
  title          Json
  description    Json?
  intro          Json?
  why            Json?
  content        Json
  calendarType   String   @default("ethiopian")
  academicYear   String
  semester       String
  targetAudience String   @default("student")
  isDraft        Boolean  @default(false)
  createdBy      User     @relation("UserTemplates", fields: [createdById], references: [id])
  createdById    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DraftTemplate {
  id             Int      @id @default(autoincrement())
  title          Json
  description    Json?
  intro          Json?
  why            Json?
  content        Json
  calendarType   String   @default("ethiopian")
  academicYear   String
  semester       String
  targetAudience String   @default("student")
  createdBy      User     @relation("UserDraftTemplates", fields: [createdById], references: [id])
  createdById    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
