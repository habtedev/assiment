datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  password     String
  name         String?
  role         Role        @relation(fields: [roleId], references: [id])
  roleId       Int
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?
  college      College?    @relation(fields: [collegeId], references: [id])
  collegeId    Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  templates      Template[]      @relation("UserTemplates")
  draftTemplates DraftTemplate[] @relation("UserDraftTemplates")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g., 'PRESIDENT', 'COLLEGE_ADMIN', 'DEPARTMENT_ADMIN', etc.
  users User[]
}

model Department {
  id           Int     @id @default(autoincrement())
  name         String  @unique // e.g., 'Computer Science', 'IT', etc.
  code         String? @unique // Department code (optional for existing records)
  email        String? // Contact email
  phone        String? // Contact phone
  academicYear String? // Academic year
  college      College @relation(fields: [collegeId], references: [id])
  collegeId    Int
  users        User[]
}

model College {
  id           Int          @id @default(autoincrement())
  name         Json // { en: string, am: string }
  code         String       @unique
  description  Json // { en: string, am: string }
  email        String
  phone        String
  address      Json // { en: string, am: string }
  academicYear String
  status       String // "active" | "inactive"
  users        User[]
  departments  Department[]
}

model Template {
  id             Int      @id @default(autoincrement())
  title          Json
  description    Json?
  intro          Json?
  why            Json?
  content        Json
  calendarType   String   @default("ethiopian")
  academicYear   String
  semester       String
  targetAudience String   @default("student")
  isDraft        Boolean  @default(false)
  createdBy      User     @relation("UserTemplates", fields: [createdById], references: [id])
  createdById    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DraftTemplate {
  id             Int      @id @default(autoincrement())
  title          Json
  description    Json?
  intro          Json?
  why            Json?
  content        Json
  calendarType   String   @default("ethiopian")
  academicYear   String
  semester       String
  targetAudience String   @default("student")
  createdBy      User     @relation("UserDraftTemplates", fields: [createdById], references: [id])
  createdById    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
